#!/usr/bin/env bash
# Wrapper — activates the venv and runs manage.py
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON="$SCRIPT_DIR/venv/bin/python3"

if [ ! -f "$PYTHON" ]; then
    echo "venv not found. Run: python3.10 -m venv venv && source venv/bin/activate && pip install -r requirements.txt"
    exit 1
fi

exec "$PYTHON" "$SCRIPT_DIR/manage.py" "$@"
