#!/usr/bin/env bash
# Wrapper — uses venv if available, falls back to system python
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/venv/bin/python3"

if [ -f "$VENV_PYTHON" ]; then
    PYTHON="$VENV_PYTHON"
else
    PYTHON="$(which python3)"
    echo "[warn] venv not found, using system python ($PYTHON)" >&2
    echo "[warn] For a clean setup: python3.10 -m venv venv && source venv/bin/activate && pip install -r requirements.txt" >&2
fi

exec "$PYTHON" "$SCRIPT_DIR/manage.py" "$@"
